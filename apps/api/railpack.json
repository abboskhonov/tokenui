{
  "$schema": "https://schema.railpack.com",
  "provider": "bun",
  "steps": {
    "install": {
      "commands": ["bun install --frozen-lockfile"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["echo 'Build step complete'"]
    }
  },
  "deploy": {
    "startCommand": "bun run src/index.ts",
    "paths": ["/app/node_modules/.bin"]
  }
}
